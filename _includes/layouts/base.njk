<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description }}">
  <title>{{ title }}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32">
  {% if og %}
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ og.url }}">
  <meta property="og:title" content="{{ og.title }}">
  <meta property="og:description" content="{{ og.description }}">
  <meta property="og:image" content="{{ og.image }}">
  <meta property="og:image:width" content="2408">
  <meta property="og:image:height" content="1432">
  <meta property="og:image:alt" content="{{ og.imageAlt }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ og.title }}">
  <meta name="twitter:description" content="{{ og.description }}">
  <meta name="twitter:image" content="{{ og.image }}">
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="{{ fontUrl }}" rel="stylesheet">
  <link rel="stylesheet" href="/components/creamy-orb.css">
  <link rel="stylesheet" href="/components/media-skeleton.css">
  <link rel="stylesheet" href="/nav.css">
  <link rel="stylesheet" href="/{{ stylesheet }}" id="page-stylesheet">
</head>
<body data-page="{{ pageId }}"{% if projectSlug %} data-project-slug="{{ projectSlug }}"{% endif %}>
  {% include "partials/site-header.njk" %}
  {{ content | safe }}
  {% include "partials/site-footer.njk" %}
  {% include "partials/site-scripts.njk" %}
</body>
</html>
