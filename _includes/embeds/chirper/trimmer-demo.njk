<div class="project-embed" data-project-embed="chirper-trimmer">
  <div class="chirper-trimmer" data-chirper-trimmer>
    <div class="chirper-trimmer__chrome">
      <div class="chirper-trimmer__top">
        <div class="chirper-trimmer__file">
          <span class="chirper-trimmer__bird" aria-hidden="true">♪</span>
          <div>
            <p class="chirper-trimmer__name">dawn-chorus.wav</p>
            <p class="chirper-trimmer__meta">Field recording · 0:24</p>
          </div>
        </div>
        <button type="button" class="chirper-trimmer__play" data-chirper-play aria-label="Play trimmed clip">
          <span data-chirper-play-icon aria-hidden="true">▶</span>
        </button>
      </div>
      <div class="chirper-trimmer__wave" data-chirper-wave>
        <div class="chirper-trimmer__bars" aria-hidden="true">
          <span style="--h: 28%"></span><span style="--h: 46%"></span><span style="--h: 62%"></span>
          <span style="--h: 38%"></span><span style="--h: 74%"></span><span style="--h: 52%"></span>
          <span style="--h: 88%"></span><span style="--h: 41%"></span><span style="--h: 67%"></span>
          <span style="--h: 33%"></span><span style="--h: 79%"></span><span style="--h: 55%"></span>
          <span style="--h: 91%"></span><span style="--h: 48%"></span><span style="--h: 36%"></span>
          <span style="--h: 70%"></span><span style="--h: 58%"></span><span style="--h: 44%"></span>
          <span style="--h: 82%"></span><span style="--h: 39%"></span><span style="--h: 63%"></span>
          <span style="--h: 51%"></span><span style="--h: 76%"></span><span style="--h: 42%"></span>
          <span style="--h: 69%"></span><span style="--h: 57%"></span><span style="--h: 85%"></span>
          <span style="--h: 31%"></span><span style="--h: 49%"></span><span style="--h: 72%"></span>
        </div>
        <div class="chirper-trimmer__selection" data-chirper-selection></div>
        <button type="button" class="chirper-trimmer__handle chirper-trimmer__handle--start" data-chirper-handle="start" aria-label="Trim start"></button>
        <button type="button" class="chirper-trimmer__handle chirper-trimmer__handle--end" data-chirper-handle="end" aria-label="Trim end"></button>
      </div>
      <div class="chirper-trimmer__footer">
        <p class="chirper-trimmer__range" data-chirper-range>0:04 – 0:18</p>
        <button type="button" class="chirper-trimmer__export" data-chirper-export>Export clip</button>
      </div>
    </div>
    <p class="chirper-trimmer__hint">Hover the handles · drag to trim · click play</p>
  </div>
</div>
